{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "typecheck": { "dependsOn": ["^build"] },
    "db:push": { "cache": false },
    "db:studio": { "cache": false, "persistent": true }
  }
}
